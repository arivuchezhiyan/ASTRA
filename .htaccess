RewriteEngine On
# Comment out RewriteBase for Hostinger compatibility so rewrites are relative to the installation folder
# RewriteBase /photo/astroclicks/

# Protect .env file
<Files .env>
    Order allow,deny
    Deny from all
</Files>

# Protect app directory
RewriteRule ^app/ - [F,L]

# SEO Friendly URLs
# Services listing
RewriteRule ^services/?$ services.php [L,QSA]

# Service detail page
RewriteRule ^services/([a-zA-Z0-9-]+)/?$ service-details.php?slug=$1 [L,QSA]

# Blog listing
RewriteRule ^blogs/?$ blogs.php [L,QSA]

# Blog detail page
RewriteRule ^blog/([a-zA-Z0-9-]+)/?$ blog-details.php?slug=$1 [L,QSA]

# Gallery
RewriteRule ^gallery/?$ gallery.php [L,QSA]

# Contact
RewriteRule ^contact/?$ contact.php [L,QSA]

# Prevent directory listing
Options -Indexes

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# GZIP Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
